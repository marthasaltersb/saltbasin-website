# Required for the editor agent and BestyStaff (Phase 3 / Phase 5)
ANTHROPIC_API_KEY=

# Cookie signing secret. Generate a long random string before deploying.
SESSION_SECRET=change-me-to-a-long-random-string

# Initial admin user — created on first server boot if no users exist.
ADMIN_EMAIL=betsy@saltbasin.net
ADMIN_INITIAL_PASSWORD=ChangeMeOnFirstLogin

# Server port (client dev server proxies /api to this)
PORT=3001
